{
  "manifest_version": 3,
  "name": "GhostJob - Ghost Job Detector",
  "version": "1.0.7",
  "description": "Detect ghost jobs on LinkedIn with Trust Score",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://jobghost-gamma.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/GhostJob4_logov1.2_16x.png",
      "48": "icons/GhostJob4_logov1.2_48x.png",
      "128": "icons/GhostJob4_logov1.2_128x.png"
    }
  },
  "icons": {
    "16": "icons/GhostJob4_logov1.2_16x.png",
    "48": "icons/GhostJob4_logov1.2_48x.png",
    "128": "icons/GhostJob4_logov1.2_128x.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}