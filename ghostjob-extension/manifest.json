{
  "manifest_version": 3,
  "name": "GhostJob - Ghost Job Detector",
  "version": "1.0.0",
  "description": "Detect ghost jobs on LinkedIn with Ghost Score",
  "permissions": [
    "activeTab",
    "storage",
    "https://jobghost-gamma.vercel.app/*"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/view/*",
    "https://jobghost-gamma.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}